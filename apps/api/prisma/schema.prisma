generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  vendor
  admin
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  phone        String?     @unique
  passwordHash String
  fullName     String?
  role      AdminRole @default(USER)
  status       UserStatus  @default(ACTIVE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  customer     Customer?
  vendorProfile VendorProfile?
}

model Customer {
  id             String    @id @default(uuid())
  userId         String    @unique
  firstName      String?
  lastName       String?
  phone          String?
  address        String?
  city           String?
  state          String?
  country        String?
  zipCode        String?
 loyaltyPoints  Int       @default(0)
  totalOrders    Int       @default(0)
  totalSpent     Decimal   @db.Decimal(12, 2) @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
}

model Vendor {
  id          String   @id @default(uuid())
  userId      String   @unique
  businessName String?
  kycStatus   String   @default("DRAFT")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([parentId])
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  logoUrl   String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String          @id @default(uuid())
  vendorId    String
  categoryId  String
  brandId     String?
  name        String
  slug        String          @unique
  description String
  status      String          @default("PENDING_MODERATION")
  isActive    Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  category    Category        @relation(fields: [categoryId], references: [id])
  brand       Brand?          @relation(fields: [brandId], references: [id], onDelete: SetNull)
  variations  SkuVariation[]
  images      ProductImage[]
}

model SkuVariation {
  id                String   @id @default(uuid())
  productId         String
  sku               String   @unique
  barcode           String?
  name              String?
  color             String?
  size              String?
  price             Decimal  @db.Decimal(12, 2)
  salePrice         Decimal? @db.Decimal(12, 2)
  weightKg          Decimal? @db.Decimal(10, 3)
  dimensionsJson    Json?
  lowStockThreshold Int      @default(5)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}


model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  altText   String?
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}


enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  INITIATED
  SUCCESS
  FAILED
  REFUNDED
}

enum CartItemFulfillmentType {
  EXPRESS
  DROPSHIP
}

model CartItem {
  id             String   @id @default(uuid())
  userId         String
  skuVariationId String
  quantity       Int      @default(1)
  fulfillmentType CartItemFulfillmentType
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, skuVariationId, fulfillmentType])
  @@index([userId])
}

model Order {
  id                 String        @id @default(uuid())
  customerId         String
  totalAmount        Decimal       @db.Decimal(12, 2)
  shippingFee        Decimal       @db.Decimal(12, 2)
  status             OrderStatus   @default(PENDING_PAYMENT)
  paymentStatus      PaymentStatus @default(INITIATED)
  deliveryAddressId  String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  items              OrderItem[]
}


enum PaymentGateway {
  PAYSTACK
  FLUTTERWAVE
  CASH
  WALLET
}

model PaymentTransaction {
  id             String          @id @default(uuid())
  orderId        String?
  gateway        PaymentGateway
  reference      String          @unique
  amount         Decimal         @db.Decimal(12, 2)
  status         String          @default("INITIATED")
  webhookPayload Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  order          Order?          @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model OrderTimeline {
  id        String   @id @default(uuid())
  orderId   String
  status    String
  location  String?
  note      String?
  createdAt DateTime @default(now())

  @@index([orderId])
}

model VendorOrder {
  id             String   @id @default(uuid())
  orderId        String
  vendorId       String
  status         String   @default("AWAITING_ACCEPTANCE")
  acceptDeadline DateTime
  shipDeadline   DateTime
  acceptTimestamp DateTime?
  shipTimestamp   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orderId])
}

model EscrowLedger {
  id           String   @id @default(uuid())
  transactionId String?
  orderId      String
  amount       Decimal  @db.Decimal(12, 2)
  entryType    String
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orderId])
}

enum WarehouseType {
  FC
  HUB
}

model Warehouse {
  id        String         @id @default(uuid())
  name      String
  city      String?
  type      WarehouseType  @default(HUB)
  lat       Decimal?       @db.Decimal(10, 7)
  lon       Decimal?       @db.Decimal(10, 7)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  inventories ProductInventory[]
}

model ProductInventory {
  id             String   @id @default(uuid())
  warehouseId    String
  skuVariationId String
  availableQty   Int      @default(0)
  reservedQty    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  warehouse      Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  skuVariation   SkuVariation      @relation(fields: [skuVariationId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, skuVariationId])
  @@index([warehouseId])
  @@index([skuVariationId])
}

model InventoryReservation {
  id             String   @id @default(uuid())
  warehouseId    String
  skuVariationId String
  quantity       Int
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  @@index([warehouseId, skuVariationId])
}

model ShippingZone {
  id          String   @id @default(uuid())
  fromCityId  String
  toCityId    String
  baseFee     Decimal  @db.Decimal(10, 2)
  perKgFee    Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([fromCityId, toCityId])
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

enum TransactionType {
  PAYMENT
  COMMISSION
  REFUND
  PAYOUT
  VENDOR_CREDIT
  ESCROW_HOLD
  ESCROW_RELEASE
  STORAGE_FEE
  ADJUSTMENT
}

model GeneralLedger {
  id          String           @id @default(uuid())
  transactionId String
  entryType   LedgerEntryType
  account     String
  amount      Decimal          @db.Decimal(12, 2)
  description String?
  createdAt   DateTime         @default(now())

  @@index([transactionId])
}

model FinancialTransaction {
  id          String           @id @default(uuid())
  type        TransactionType
  reference   String           @unique
  amount      Decimal          @db.Decimal(12, 2)
  status      String           @default("PENDING")
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  entries     GeneralLedger[]
}


enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum VendorLevel {
  BASIC
  PREMIUM
  ENTERPRISE
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  SUPPORT
}

model VendorProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  companyName String
  businessType String
  kycStatus   KycStatus @default(PENDING)
  vendorLevel VendorLevel @default(BASIC)
  kycDocuments Json?
  rejectionReason String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  vendorOrders VendorOrder[]
}

model KycDocument {
  id          String   @id @default(uuid())
  vendorId    String
  type        String   // BUSINESS_LICENSE, ID_CARD, UTILITY_BILL, BANK_STATEMENT
  url         String
  status      String   @default("PENDING")
  reviewedAt  DateTime?
  reviewedBy  String?
  createdAt   DateTime @default(now())

  vendor      VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model CommissionConfig {
  id          String   @id @default(uuid())
  categoryIds String?  // comma-separated
  countryId   String?
  type        String   // PERCENT, FIXED
  value       Decimal  @db.Decimal(10, 2)
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
}

model AdminActivityLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model ProductModerationQueue {
  id          String   @id @default(uuid())
  productId   String   @unique
  status      String   @default("PENDING")
  flaggedBy   String?
  reason      String?
  reviewedAt  DateTime?
  reviewedBy  String?
  createdAt   DateTime @default(now())

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}


// Reviews & Ratings
model Review {
  id          String   @id @default(uuid())
  productId   String
  orderId     String
  userId      String
  rating      Int
  comment     String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([userId])
}

// Refunds & Returns
enum RefundStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  CANCELLED
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  SHIPPED
  RECEIVED
  INSPECTED
  COMPLETED
  REJECTED
}

model Refund {
  id          String       @id @default(uuid())
  orderId     String
  orderItemId String?
  amount      Decimal      @db.Decimal(12, 2)
  reason      String
  status      RefundStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([orderId])
}

model Return {
  id            String       @id @default(uuid())
  orderId       String
  orderItemId   String
  reason        String
  description   String?
  status        ReturnStatus @default(REQUESTED)
  trackingNumber String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([orderId])
}

// Disputes
enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  ESCALATED
  CLOSED
}

model Dispute {
  id          String        @id @default(uuid())
  orderId     String
  type        String        // ORDER_ISSUE, PAYMENT_ISSUE, PRODUCT_ISSUE
  reason      String
  description String
  status      DisputeStatus @default(OPEN)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([orderId])
}

// Wallets & Payouts
model Wallet {
  id          String   @id @default(uuid())
  userId      String   @unique
  balance     Decimal  @db.Decimal(12, 2) @default(0)
  currency    String   @default("NGN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum WalletTransactionType {
  DEPOSIT
  WITHDRAWAL
  PAYMENT
  REFUND
  COMMISSION
  PAYOUT
  ADJUSTMENT
}

model WalletTransaction {
  id          String              @id @default(uuid())
  walletId    String
  type        WalletTransactionType
  amount      Decimal             @db.Decimal(12, 2)
  balanceAfter Decimal            @db.Decimal(12, 2)
  description String?
  reference   String?
  createdAt   DateTime            @default(now())

  @@index([walletId])
}

model Payout {
  id          String   @id @default(uuid())
  vendorId    String
  walletId    String
  amount      Decimal  @db.Decimal(12, 2)
  fee         Decimal  @db.Decimal(12, 2)
  netAmount   Decimal  @db.Decimal(12, 2)
  status      String   @default("PENDING")
  method      String   // BANK_TRANSFER, MOBILE_MONEY
  bankDetails Json
  requestedAt DateTime @default(now())
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vendorId])
  @@index([walletId])
}

// Coupons
enum CouponType {
  PERCENTAGE
  FIXED
}

enum CouponStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  USED
}

model Coupon {
  id          String       @id @default(uuid())
  code        String       @unique
  type        CouponType
  value       Decimal      @db.Decimal(10, 2)
  description String?
  minOrder    Decimal?     @db.Decimal(12, 2)
  maxDiscount Decimal?     @db.Decimal(12, 2)
  usageLimit  Int?
  usedCount   Int          @default(0)
  validFrom   DateTime
  validUntil  DateTime
  status      CouponStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model CouponUsage {
  id        String   @id @default(uuid())
  couponId  String
  userId    String
  orderId   String
  createdAt DateTime @default(now())

  @@unique([couponId, userId])
}

// Flash Sales
model FlashSale {
  id          String   @id @default(uuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      String   @default("SCHEDULED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       FlashSaleItem[]
}

model FlashSaleItem {
  id          String    @id @default(uuid())
  flashSaleId String
  productId   String
  discount    Decimal   @db.Decimal(5, 2)
  originalPrice Decimal @db.Decimal(12, 2)
  salePrice   Decimal   @db.Decimal(12, 2)
  stock       Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([flashSaleId, productId])
}

// Notifications
model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
}

// Shipping (enhanced)
model ShippingRate {
  id          String   @id @default(uuid())
  zoneId      String
  carrier     String
  service     String
  baseFee     Decimal  @db.Decimal(10, 2)
  perKgFee    Decimal  @db.Decimal(10, 2)
  minDays     Int
  maxDays     Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Order Items
model OrderItem {
  id             String   @id @default(uuid())
  orderId        String
  productId      String
  skuVariationId String
  quantity       Int
  unitPrice      Decimal  @db.Decimal(12, 2)
  discount       Decimal  @db.Decimal(12, 2) @default(0)
  subtotal       Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orderId])
}



// Search Index (for Elasticsearch/Meilisearch integration)
model ProductSearchIndex {
  id          String   @id @default(uuid())
  productId   String   @unique
  name        String
  description String
  slug        String
  categoryId  String
  brandId     String?
  vendorId    String
  price       Decimal  @db.Decimal(12, 2)
  tags        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@index([brandId])
  @@index([vendorId])
}