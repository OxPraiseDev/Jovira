# Database
DATABASE_URL="postgresql://user:password@localhost:5432/zuri_marketplace"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# App
APP_URL="http://localhost:3000"
PORT=3000
NODE_ENV=development

# Paystack
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxx"
PAYSTACK_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxx"

# Storage (for uploads)
STORAGE_URL="https://your-storage.com"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME=""
AWS_REGION="us-east-1"

# Email
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASS="your-email-password"
EMAIL_FROM="noreply@zuri-marketplace.com"

# Redis (for queues)
REDIS_URL="redis://localhost:6379"

# Admin
ADMIN_EMAIL="admin@zuri-marketplace.com"
ADMIN_PASSWORD="admin-password-change-me"